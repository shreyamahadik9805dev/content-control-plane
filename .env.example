HTTP_ADDR=:8080
# Optional in development: if unset, server defaults to postgres://ccp:ccp@localhost:5432/ccp
DATABASE_URL=postgres://ccp:ccp@localhost:5432/ccp?sslmode=disable

# iTunes Search API (no key). Use ITUNES_MOCK=true for offline / CI; false hits Apple’s endpoint.
ITUNES_BASE_URL=https://itunes.apple.com
ITUNES_MOCK=false

# Back-compat alias for mock mode (optional)
# OPEN_LIBRARY_MOCK=false

# In-memory list/detail cache TTL (seconds)
CACHE_TTL_SECONDS=30

ENV=development
